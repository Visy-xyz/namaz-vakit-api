{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": "generated/prayer-catalog.json",
      "excludeFiles": "data/**"
    },
    "api/v1/*.js": {
      "includeFiles": "generated/prayer-catalog.json",
      "excludeFiles": "data/**"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
